---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Energy Healing with Amy — Reconnect with Your Energy"
  description="Amy offers intuitive energy healing sessions and experiential classes to help you feel grounded, clear, and connected. Sessions in Easton MD, Sarasota FL, and virtually."
>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="hero noise">
    <div class="hero__bg-rings" aria-hidden="true">
      <div class="ring ring--1"></div>
      <div class="ring ring--2"></div>
      <div class="ring ring--3"></div>
    </div>

    <div class="hero__content container">
      <div class="hero__text">
        <p class="tag fade-up">Energy Healing · Mentorship · Transformation</p>
        <h1 class="hero__headline fade-up-2">
          Reconnect<br/>
          <em>with your</em><br/>
          energy.
        </h1>
        <p class="hero__sub fade-up-3">
          Intuitive energy healing sessions and experiential classes to help you feel
          grounded, clear, and deeply connected to yourself.
        </p>
        <div class="hero__actions fade-up-4">
          <a href="/book" class="btn btn--primary">Book a Session — $111</a>
          <a href="/about" class="btn btn--outline">Meet Amy</a>
        </div>
        <p class="hero__locations fade-up-4">
          <span>Easton, MD</span>
          <span class="dot">·</span>
          <span>Sarasota, FL</span>
          <span class="dot">·</span>
          <span>Virtual Worldwide</span>
        </p>
      </div>

      <div class="hero__visual">
        <div class="hero__photo-wrap">
          <div class="hero__photo-ring" aria-hidden="true"></div>
          <img
            src="/images/hero-amy.jpeg"
            alt="Amy — Energy Healer"
            class="hero__photo"
            width="340"
            height="420"
            loading="eager"
          />
          <div class="hero__photo-badge">
            <span class="tag">Since 1998</span>
            <span class="hero__photo-badge-label">Healing through energy</span>
          </div>
        </div>
      </div>
    </div>

  </section>

  <!-- ── MARQUEE STRIP ─────────────────────────────────── -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {Array.from({ length: 6 }).map(() => (
        <>
          <span>✦ Energy Healing</span>
          <span>✦ Chakra Balancing</span>
          <span>✦ Emotional Release</span>
          <span>✦ Astral Body Work</span>
          <span>✦ Deep Relaxation</span>
          <span>✦ Grounding &amp; Clarity</span>
          <span>✦ Reiki &amp; Beyond</span>
          <span>✦ Spiritual Mentorship</span>
        </>
      ))}
    </div>
  </div>

  <!-- ── INTRO / ABOUT TEASER ──────────────────────────── -->
  <section class="intro">
    <div class="container intro__grid">
      <div class="intro__left reveal">
        <div class="intro__quote-block">
          <svg class="intro__quote-mark" width="48" height="36" viewBox="0 0 48 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 36V22.5C0 9.5 7.5 2.5 22.5 0L24 4C17 5.5 13.5 9 13.5 14H21V36H0ZM27 36V22.5C27 9.5 34.5 2.5 49.5 0L51 4C44 5.5 40.5 9 40.5 14H48V36H27Z" fill="var(--gold)" opacity="0.25"/>
          </svg>
          <blockquote class="intro__quote">
            "In just two sessions I found relief. I am back on the golf course, in the gym and back in the pool doing aerobics."
          </blockquote>
          <cite class="intro__cite">John Bunting — #95, Philadelphia Eagles (1972–1982)</cite>
        </div>
      </div>

      <div class="intro__right reveal">
        <span class="tag">About Amy</span>
        <div class="divider"></div>
        <h2>A healer who has walked the path of transformation herself.</h2>
        <p>
          Amy began her journey with Usui Reiki in 1998 — not as a practitioner, but as someone seeking her own healing. Through years of intensive inner work and training under world-renowned healer Charlie Goldsmith, she developed her own profound hands-on technique that goes far beyond traditional Reiki.
        </p>
        <p style="margin-top: 1rem;">
          Today, Amy helps clients release energetic blockages, soothe chronic stress, and reconnect with their deepest selves — in person and virtually.
        </p>
        <a href="/about" class="btn btn--outline" style="margin-top: 2rem;">
          Read Amy's Story
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── SERVICES ──────────────────────────────────────── -->
  <section class="services-section">
    <div class="container">
      <div class="section-header reveal">
        <span class="tag">What Amy Offers</span>
        <div class="divider divider--center"></div>
        <h2>Choose your healing path</h2>
        <p class="section-sub">Every session is uniquely tailored to where you are right now.</p>
      </div>

      <div class="services-grid">
        <!-- Card 1 -->
        <article class="service-card reveal">
          <div class="service-card__num">01</div>
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3>Custom Healing Session</h3>
          <p>One-on-one energy healing designed to support emotional release, balance, and deep relaxation. Amy's signature technique combines Reiki elements with astral body work for profound results.</p>
          <div class="service-card__footer">
            <div class="service-card__price">$111 <span>/ 45 min</span></div>
            <a href="/book" class="btn btn--primary">Book Now</a>
          </div>
        </article>

        <!-- Card 2 -->
        <article class="service-card reveal" style="animation-delay: 0.1s">
          <div class="service-card__num">02</div>
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>Alignment Path</h3>
          <p>Monthly 1:1 mentorship to deepen your connection to intuition and energy. Includes chakra awareness, grounding practices, personalized integration exercises, and between-session check-ins.</p>
          <div class="service-card__footer">
            <div class="service-card__price">$222 <span>/ month</span></div>
            <a href="/services" class="btn btn--outline">Learn More</a>
          </div>
        </article>

        <!-- Card 3 -->
        <article class="service-card service-card--featured reveal" style="animation-delay: 0.2s">
          <div class="service-card__badge">Most Comprehensive</div>
          <div class="service-card__num">03</div>
          <div class="service-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--gold-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <h3>Expansion Path</h3>
          <p>Full-access mentorship with one monthly session plus ongoing voice and text support. Receive in-depth personalized guidance whenever you need it — Amy responds within 24–48 hours.</p>
          <div class="service-card__footer">
            <div class="service-card__price">$333 <span>/ month</span></div>
            <a href="/services" class="btn btn--gold">Learn More</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ── WHAT TO EXPECT ─────────────────────────────────── -->
  <section class="process">
    <div class="container">
      <div class="section-header reveal">
        <span class="tag">The Process</span>
        <div class="divider divider--center"></div>
        <h2>What to expect</h2>
      </div>

      <div class="process__steps">
        {[
          { n: '01', title: 'Reach out & connect', body: 'Book online or call Amy directly. She\'ll answer any questions and make sure the session is right for you.' },
          { n: '02', title: 'Your healing session', body: 'In a safe, calm space, Amy uses her unique hands-on technique to identify and dissolve energetic blockages throughout your body.' },
          { n: '03', title: 'Release & integrate', body: 'Feel a deep sense of release — emotional, physical, and energetic. Many clients notice shifts immediately after their first session.' },
          { n: '04', title: 'Ongoing support', body: 'With mentorship paths, Amy supports your journey with education, tools, and consistent guidance between sessions.' },
        ].map((step) => (
          <div class="process__step reveal">
            <div class="process__step-num">{step.n}</div>
            <div class="process__step-content">
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER ───────────────────────────────────────── -->
  <section class="newsletter">
    <div class="container newsletter__inner reveal">
      <div class="newsletter__text">
        <span class="tag">Stay Connected</span>
        <h3>Be the first to hear about upcoming classes and offerings.</h3>
      </div>
      <form
        class="newsletter__form"
        name="newsletter"
        method="POST"
        data-netlify="true"
        action="/"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <input
          type="email"
          name="email"
          placeholder="Your email address"
          required
          aria-label="Email address"
        />
        <button type="submit" class="btn btn--primary">Subscribe</button>
      </form>
    </div>
  </section>

  <!-- ── CTA BANNER ────────────────────────────────────── -->
  <section class="cta-banner noise">
    <div class="cta-banner__rings" aria-hidden="true">
      <div class="cta-ring cta-ring--1"></div>
      <div class="cta-ring cta-ring--2"></div>
    </div>
    <div class="container cta-banner__inner reveal">
      <span class="tag" style="color: var(--gold-light)">Begin your journey</span>
      <h2>Ready to return to yourself?</h2>
      <p>Take the first step. A single session can open doors you didn't know were closed.</p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 2rem;">
        <a href="/book" class="btn btn--gold">Book a Session — $111</a>
        <a href="/contact" class="btn btn--outline" style="border-color: rgba(253,250,245,0.4); color: var(--cream);">Get in Touch</a>
      </div>
      <p class="cta-banner__contact">
        Or call Amy directly: <a href="tel:+16106089347">610-608-9347</a>
      </p>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    background: var(--cream);
    overflow: hidden;
    padding-top: clamp(7rem, 12vw, 9rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero__bg-rings {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid var(--gold);
    opacity: 0.12;
  }
  .ring--1 { width: 600px; height: 600px; right: -160px; top: -100px; }
  .ring--2 { width: 900px; height: 900px; right: -400px; top: -300px; opacity: 0.06; }
  .ring--3 { width: 400px; height: 400px; right: 40px; bottom: -120px; opacity: 0.08; }

  .hero__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero__text .tag { color: var(--sage-dark); margin-bottom: 1.5rem; display: block; }

  .hero__headline {
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--brown);
    margin-bottom: 1.75rem;
  }

  .hero__headline em {
    font-style: italic;
    color: var(--sage-dark);
  }

  .hero__sub {
    font-size: 1rem;
    color: var(--brown-light);
    max-width: 440px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero__locations {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .hero__locations .dot { color: var(--gold); }

  /* Photo */
  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__photo-wrap {
    position: relative;
    animation: float 6s ease-in-out infinite;
  }

  .hero__photo-ring {
    position: absolute;
    inset: -16px;
    border: 1px solid var(--gold);
    opacity: 0.3;
    pointer-events: none;
  }

  .hero__photo {
    display: block;
    width: 340px;
    height: 420px;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.9) brightness(1.02);
  }

  .hero__photo-badge {
    position: absolute;
    bottom: -1.25rem;
    right: -1.5rem;
    background: var(--brown);
    padding: 0.85rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-left: 3px solid var(--gold);
  }

  .hero__photo-badge .tag { color: var(--gold-light); }

  .hero__photo-badge-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9rem;
    color: rgba(253,250,245,0.7);
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    z-index: 2;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollLine 1.8s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50%       { transform: scaleY(0.4); opacity: 0.4; }
  }

  /* ── Marquee ────────────────────────────────────────── */
  .marquee {
    background: var(--brown);
    padding: 0.9rem 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .marquee__track {
    display: inline-flex;
    gap: 2.5rem;
    animation: marqueeScroll 40s linear infinite;
  }

  .marquee__track span {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(253,250,245,0.6);
    white-space: nowrap;
  }

  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Intro ──────────────────────────────────────────── */
  .intro { background: var(--cream-dark); }

  .intro__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .intro__quote-block {
    position: relative;
    padding: 2.5rem;
    background: var(--cream);
    border-left: 3px solid var(--gold);
  }

  .intro__quote-mark {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    pointer-events: none;
  }

  .intro__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--brown);
    margin-bottom: 1.25rem;
    padding-top: 1rem;
  }

  .intro__cite {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage-dark);
    font-style: normal;
  }

  /* ── Services ───────────────────────────────────────── */
  .services-section { background: var(--cream); }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-sub {
    color: var(--brown-light);
    margin-top: 0.75rem;
    font-size: 0.95rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: var(--cream-dark);
    border: 1px solid var(--parchment);
    padding: 2.5rem 2rem;
    position: relative;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), box-shadow 0.35s;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(28,24,16,0.1);
  }

  .service-card--featured {
    background: var(--brown);
    border-color: var(--brown);
    color: var(--cream);
  }

  .service-card--featured h3,
  .service-card--featured p { color: rgba(253,250,245,0.85); }

  .service-card--featured .service-card__price { color: var(--gold-light); }
  .service-card--featured .service-card__price span { color: rgba(253,250,245,0.4); }

  .service-card__badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: var(--gold);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
  }

  .service-card__num {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.2;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .service-card--featured .service-card__num { opacity: 0.15; color: var(--gold-light); }

  .service-card__icon { margin-bottom: 1rem; }

  .service-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    color: var(--brown);
  }

  .service-card p { font-size: 0.87rem; }

  .service-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .service-card__price {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--brown);
  }

  .service-card__price span {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--muted);
  }

  /* ── Process ───────────────────────────────────────── */
  .process { background: var(--cream-dark); }

  .process__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  .process__steps::before {
    content: '';
    position: absolute;
    top: 24px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: var(--gold);
    opacity: 0.2;
  }

  .process__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.5rem;
    gap: 1rem;
  }

  .process__step-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--cream);
    border: 1px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--gold);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .process__step-content h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--brown);
  }

  .process__step-content p { font-size: 0.85rem; }

  /* ── Newsletter ─────────────────────────────────────── */
  .newsletter { background: var(--cream-dark); border-top: 1px solid var(--parchment); border-bottom: 1px solid var(--parchment); }

  .newsletter__inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .newsletter__text { flex: 1; min-width: 260px; }
  .newsletter__text .tag { color: var(--sage-dark); display: block; margin-bottom: 0.5rem; }
  .newsletter__text h3 { font-size: clamp(1.1rem, 2vw, 1.4rem); font-weight: 400; color: var(--brown); }

  .newsletter__form {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .newsletter__form input {
    padding: 0.85rem 1.25rem;
    background: var(--cream);
    border: 1px solid var(--parchment);
    color: var(--brown);
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    min-width: 260px;
    transition: border-color 0.25s;
  }

  .newsletter__form input:focus { border-color: var(--gold); }
  .newsletter__form input::placeholder { color: var(--muted); }

  /* ── CTA Banner ─────────────────────────────────────── */
  .cta-banner {
    background: var(--brown);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .cta-banner__rings { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

  .cta-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(196,151,90,0.15);
  }

  .cta-ring--1 { width: 600px; height: 600px; top: -200px; left: -150px; }
  .cta-ring--2 { width: 500px; height: 500px; bottom: -200px; right: -100px; }

  .cta-banner__inner { position: relative; z-index: 2; }
  .cta-banner__inner h2 { color: var(--cream); margin: 0.75rem 0; }
  .cta-banner__inner p  { color: rgba(253,250,245,0.65); max-width: 480px; margin: 0 auto; }

  .cta-banner__contact {
    margin-top: 1.5rem;
    font-size: 0.82rem;
    color: rgba(253,250,245,0.4);
  }

  .cta-banner__contact a {
    color: var(--gold-light);
    transition: color 0.2s;
  }

  .cta-banner__contact a:hover { color: var(--cream); }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
    .process__steps { grid-template-columns: 1fr 1fr; }
