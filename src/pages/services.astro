---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Services & Pricing — Energy Healing Sessions & Mentorship"
  description="Explore Amy's energy healing services: Custom Healing Sessions ($111/45min), Alignment Path mentorship ($222/mo), and Expansion Path mentorship ($333/mo). Book online or virtually."
>

  <!-- ── PAGE HERO ────────────────────────────────────── -->
  <section class="page-hero">
    <div class="page-hero__accent services-accent" aria-hidden="true"></div>
    <div class="container page-hero__split">
      <div class="page-hero__body">
        <span class="tag fade-up">Services & Pricing</span>
        <h1 class="fade-up-2">Every healing journey<br/><em>begins with one step</em></h1>
        <div class="divider fade-up-3"></div>
        <p class="page-hero__sub fade-up-4">
          Whether you're new to energy work or deepening an existing practice, Amy
          offers a path that meets you exactly where you are.
        </p>
      </div>
      <div class="page-hero__img fade-in">
        <img
          src="/images/healing-hands.webp"
          alt="Energy healing hands-on session"
          width="500"
          height="400"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ── CUSTOM SESSION ────────────────────────────────── -->
  <section class="primary-service">
    <div class="container primary-service__grid">

      <div class="primary-service__image reveal">
        <img
          src="/images/session-2.jpg"
          alt="One-on-one healing session with Amy"
          loading="lazy"
        />
        <div class="primary-service__badge">
          <span class="primary-service__badge-price">$111</span>
          <span class="primary-service__badge-dur">45 min</span>
        </div>
      </div>

      <div class="primary-service__text">
        <div class="reveal">
          <span class="tag">Signature Offering</span>
          <div class="divider"></div>
          <h2>Custom Healing Session</h2>
          <p>
            Amy's one-on-one healing sessions are unlike anything else you'll experience. Working
            with her signature technique — an evolution of Usui Reiki that incorporates astral body
            work — she identifies and dissolves the energetic blockages keeping you from feeling
            your best.
          </p>
          <p>
            Sessions are deeply intuitive and personalized. Amy follows the energy, going exactly
            where healing is needed. Each session lasts 45 minutes and is available in person or
            virtually.
          </p>
        </div>

        <ul class="benefits-list reveal">
          {[
            'Emotional release and energetic balance',
            'Relief from stress, tension, and insomnia',
            'Support for physical ailments',
            'Deep relaxation and clarity',
            'Astral body and chakra work',
            'Available in-person or virtually',
          ].map((item) => (
            <li>
              <span class="benefit-check" aria-hidden="true">✦</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>

        <div class="reveal primary-service__ctas">
          <a href="/book"    class="btn btn--primary">Book a Session — $111</a>
          <a href="/contact" class="btn btn--outline">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CHAKRA SECTION ───────────────────────────────────── -->
  <section class="chakra-section">
    <div class="container chakra-grid">

      <div class="chakra-image reveal">
        <img
          src="/images/chakras-poster.jpg"
          alt="The seven chakra energy centers"
          loading="lazy"
        />
      </div>

      <div class="chakra-text">
        <div class="reveal">
          <span class="tag">Energy Centers</span>
          <div class="divider"></div>
          <h2>Working with your chakras</h2>
          <p>
            At the core of Amy's healing work is an awareness of the body's seven major energy
            centers — the chakras. Each one governs different aspects of your physical, emotional,
            and spiritual wellbeing. When a chakra is blocked or out of balance, it can manifest
            as pain, anxiety, fatigue, or a feeling of being stuck.
          </p>
          <p>
            Amy's sessions identify which centers need attention and restore the natural flow of
            energy throughout the body. This is not textbook theory — it is hands-on, felt work
            that clients describe as immediately tangible.
          </p>
        </div>

        <div class="chakra-list reveal">
          {[
            { name: 'Root',       color: '#c0392b', desc: 'Grounding, safety, stability'       },
            { name: 'Sacral',     color: '#e67e22', desc: 'Creativity, emotion, flow'           },
            { name: 'Solar',      color: '#f1c40f', desc: 'Confidence, will, personal power'    },
            { name: 'Heart',      color: '#27ae60', desc: 'Love, compassion, connection'        },
            { name: 'Throat',     color: '#2980b9', desc: 'Expression, truth, communication'    },
            { name: 'Third Eye',  color: '#8e44ad', desc: 'Intuition, clarity, insight'         },
            { name: 'Crown',      color: '#9b59b6', desc: 'Spiritual connection, higher wisdom' },
          ].map((c) => (
            <div class="chakra-row">
              <span class="chakra-dot" style={`background: ${c.color}`} aria-hidden="true"></span>
              <span class="chakra-name">{c.name}</span>
              <span class="chakra-desc">{c.desc}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ── MENTORSHIP ─────────────────────────────────────── -->
  <section class="mentorship">
    <div class="container">
      <div class="section-header reveal">
        <span class="tag">Ongoing Support</span>
        <div class="divider"></div>
        <h2>1:1 Mentorship Paths</h2>
        <p class="section-sub">
          For those ready to go deeper — developing your intuition, working through ongoing
          challenges, and building a lasting energy practice.
        </p>
      </div>

      <div class="mentorship__grid">
        <div class="mentorship-card reveal">
          <div class="mentorship-card__header">
            <span class="mentorship-card__name">Alignment Path</span>
            <div class="mentorship-card__price">
              <span class="mentorship-card__amount">$222</span>
              <span class="mentorship-card__per">/ month</span>
            </div>
          </div>
          <p class="mentorship-card__desc">
            Perfect for those beginning their energy journey or seeking regular monthly
            guidance and support.
          </p>
          <ul class="mentorship-card__features">
            {[
              'One 60-minute session per month',
              'Personalized integration practices',
              'Chakra awareness & balancing',
              'Grounding and protection techniques',
              '1–2 between-session check-ins',
              'Tools like pendulums introduced',
            ].map((f) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--sage-dark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" class="btn btn--outline mentorship-card__cta">Get Started</a>
        </div>

        <div class="mentorship-card mentorship-card--featured reveal">
          <div class="mentorship-card__badge">Most Comprehensive</div>
          <div class="mentorship-card__header">
            <span class="mentorship-card__name">Expansion Path</span>
            <div class="mentorship-card__price">
              <span class="mentorship-card__amount">$333</span>
              <span class="mentorship-card__per">/ month</span>
            </div>
          </div>
          <p class="mentorship-card__desc">
            Full-access mentorship for those who want Amy's guidance available whenever
            they need it most.
          </p>
          <ul class="mentorship-card__features">
            {[
              'One 60-minute session per month',
              'Unlimited between-session questions',
              'Voice or text support',
              '24–48 hour response time',
              'In-depth personalized guidance',
              'All Alignment Path features included',
            ].map((f) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gold-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" class="btn btn--gold mentorship-card__cta">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHO IT'S FOR ───────────────────────────────────── -->
  <section class="who-for">
    <div class="container">
      <div class="section-header reveal">
        <span class="tag">Is This for You?</span>
        <div class="divider"></div>
        <h2>Mentorship may be right for you if…</h2>
      </div>

      <div class="who-for__grid">
        {[
          "You're new to energy work and want a knowledgeable guide",
          "You're navigating a major life transition",
          "You want to develop your own intuitive awareness",
          "You're an experienced practitioner seeking deeper work",
          "You prefer ongoing support over standalone sessions",
          "You want practical, at-home tools to supplement sessions",
        ].map((item) => (
          <div class="who-item reveal">
            <span class="who-item__icon" aria-hidden="true">✦</span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── IMAGE BREAK ────────────────────────────────────── -->
  <div class="img-break">
    <img src="/images/river-mountain.jpg" alt="Peaceful natural landscape" loading="lazy" />
    <div class="img-break__overlay"></div>
    <div class="img-break__text container">
      <blockquote>"Reconnect with your energy. Return to yourself."</blockquote>
    </div>
  </div>

  <!-- ── DISCLAIMER + CTA ────────────────────────────────── -->
  <section class="services-footer">
    <div class="container">
      <div class="services-disclaimer reveal">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--sage-dark)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p>
          <strong>Important note:</strong> Energy Healing with Amy offers spiritual and energetic
          services only. These services are not massage therapy, bodywork, or medical care. They do
          not diagnose, treat, or cure any physical or mental health condition. Always consult a
          qualified healthcare provider for medical concerns.
        </p>
      </div>

      <div class="services-cta reveal">
        <h2>Not sure which path is right for you?</h2>
        <p>Reach out — Amy would love to chat and help you figure out the best fit.</p>
        <div class="services-cta__btns">
          <a href="/contact"         class="btn btn--primary">Contact Amy</a>
          <a href="tel:+16106089347" class="btn btn--outline">Call 610-608-9347</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Accent */
  .services-accent {
    background: radial-gradient(ellipse at 10% 50%, var(--sage-light) 0%, transparent 50%);
    opacity: 0.18;
  }

  /* ── Primary Service ────────────────────────────────── */
  .primary-service { background: var(--cream-dark); }

  .primary-service__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }

  .primary-service__image {
    position: relative;
  }

  .primary-service__image img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
    filter: saturate(0.9);
  }

  .primary-service__image::before {
    content: '';
    position: absolute;
    inset: -10px;
    border: 1px solid var(--gold);
    opacity: 0.22;
    pointer-events: none;
    z-index: -1;
  }

  .primary-service__badge {
    position: absolute;
    bottom: 1rem;
    right: -1rem;
    background: var(--brown);
    padding: 1rem 1.25rem;
    text-align: center;
    border-left: 3px solid var(--gold);
  }

  .primary-service__badge-price {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--gold-light);
    line-height: 1;
  }

  .primary-service__badge-dur {
    display: block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(253,250,245,0.55);
    margin-top: 0.25rem;
  }

  .primary-service__text .tag  { color: var(--sage-dark); display: block; }
  .primary-service__text h2    { margin-top: 1.25rem; margin-bottom: 1rem; }
  .primary-service__text p + p { margin-top: 0.85rem; }

  .benefits-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
    margin-top: 2rem;
  }

  .benefits-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.85rem;
    color: var(--brown-light);
  }

  .benefit-check {
    color: var(--gold);
    font-size: 0.6rem;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .primary-service__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  /* ── Chakra Section ─────────────────────────────────── */
  .chakra-section { background: var(--cream); }

  .chakra-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 5rem;
    align-items: start;
  }

  .chakra-image img {
    width: 100%;
    display: block;
    border: 1px solid var(--parchment);
    filter: saturate(0.92);
    transition: filter 0.4s;
  }

  .chakra-image:hover img { filter: saturate(1); }

  .chakra-text .tag  { color: var(--sage-dark); display: block; }
  .chakra-text h2    { margin-top: 1.25rem; margin-bottom: 1rem; }
  .chakra-text p + p { margin-top: 0.85rem; }

  .chakra-list {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--parchment);
  }

  .chakra-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 1.25rem;
    border-bottom: 1px solid var(--parchment);
    transition: background 0.2s;
  }

  .chakra-row:last-child { border-bottom: none; }
  .chakra-row:hover { background: var(--cream-dark); }

  .chakra-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .chakra-name {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brown);
    width: 80px;
    flex-shrink: 0;
  }

  .chakra-desc {
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* ── Mentorship ─────────────────────────────────────── */
  .mentorship { background: var(--cream); }

  .mentorship__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .mentorship-card {
    padding: 2.5rem;
    border: 1px solid var(--parchment);
    background: var(--cream-dark);
    position: relative;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }

  .mentorship-card:hover { transform: translateY(-4px); }

  .mentorship-card--featured {
    background: var(--brown);
    border-color: var(--brown);
  }

  .mentorship-card__badge {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    background: var(--gold);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
  }

  .mentorship-card__name {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage-dark);
    display: block;
    margin-bottom: 0.75rem;
  }

  .mentorship-card--featured .mentorship-card__name { color: var(--gold-light); }

  .mentorship-card__price { display: flex; align-items: baseline; gap: 0.3rem; margin-bottom: 1rem; }

  .mentorship-card__amount {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 400;
    color: var(--brown);
    line-height: 1;
  }

  .mentorship-card--featured .mentorship-card__amount { color: var(--cream); }

  .mentorship-card__per { font-size: 0.8rem; color: var(--muted); }
  .mentorship-card--featured .mentorship-card__per { color: rgba(253,250,245,0.45); }

  .mentorship-card__desc {
    font-size: 0.87rem;
    color: var(--brown-light);
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--parchment);
    padding-bottom: 1.5rem;
  }

  .mentorship-card--featured .mentorship-card__desc {
    color: rgba(253,250,245,0.7);
    border-color: rgba(255,255,255,0.1);
  }

  .mentorship-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .mentorship-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--brown-light);
  }

  .mentorship-card--featured .mentorship-card__features li { color: rgba(253,250,245,0.75); }

  .mentorship-card__features li svg { flex-shrink: 0; margin-top: 2px; }

  .mentorship-card__cta { width: 100%; justify-content: center; }

  /* ── Who For ────────────────────────────────────────── */
  .who-for { background: var(--cream-dark); }

  .who-for__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .who-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--cream);
    border: 1px solid var(--parchment);
    transition: transform 0.25s;
  }

  .who-item:hover { transform: translateY(-3px); }
  .who-item__icon { color: var(--gold); font-size: 0.65rem; flex-shrink: 0; margin-top: 5px; }
  .who-item p     { font-size: 0.87rem; }

  /* ── Image break ────────────────────────────────────── */
  .img-break {
    position: relative;
    height: 320px;
    overflow: hidden;
  }

  .img-break img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
    filter: saturate(0.7) brightness(0.7);
  }

  .img-break__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(28,24,16,0.55) 0%, rgba(28,24,16,0.25) 100%);
  }

  .img-break__text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
  }

  .img-break__text blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 400;
    color: var(--cream);
    max-width: 600px;
    line-height: 1.4;
  }

  /* ── Footer ─────────────────────────────────────────── */
  .services-footer { background: var(--cream); }

  .services-disclaimer {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: var(--cream-dark);
    border: 1px solid var(--parchment);
    border-left: 3px solid var(--sage);
    padding: 1.25rem 1.5rem;
    margin-bottom: 4rem;
  }

  .services-disclaimer svg    { flex-shrink: 0; margin-top: 2px; }
  .services-disclaimer p      { font-size: 0.82rem; color: var(--muted); }
  .services-disclaimer strong { color: var(--brown); }

  .services-cta { text-align: center; max-width: 560px; margin: 0 auto; }
  .services-cta h2 { margin-bottom: 0.75rem; }
  .services-cta p  { font-size: 0.95rem; }

  .services-cta__btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 2rem;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 1024px) {
    .who-for__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 768px) {
    .primary-service__grid { grid-template-columns: 1fr; }
    .chakra-grid            { grid-template-columns: 1fr; gap: 2.5rem; }
    .mentorship__grid       { grid-template-columns: 1fr; }
    .who-for__grid          { grid-template-columns: 1fr; }
    .primary-service__badge { right: 0; }
    .img-break              { height: 240px; }
  }

  @media (max-width: 480px) {
    .benefits-list { grid-template-columns: 1fr; }
  }
</style>
